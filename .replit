modules = ["php", "php-8.2", "python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["atomicparsley", "ffmpeg", "ffmpeg-full", "id3v2", "imagemagick", "libsndfile"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "News Brief Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Scheduler"

[[workflows.workflow]]
name = "News Brief Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "php -S 0.0.0.0:5000 -t ."
waitForPort = 5000

[[workflows.workflow]]
name = "Scheduler"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "while true; do php scheduler.php; sleep 60; done"

[deployment]
run = ["sh", "-c", "php -S 0.0.0.0:5000 -t ."]

[[ports]]
localPort = 5000
externalPort = 80
